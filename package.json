{
  "name": "personal-website",
  "engines": {
    "node": "^24.0.0"
  },
  "version": "0.0.0",
  "author": "Jan Esser <jan@janesser.net>",
  "scripts": {
    "ng": "ng",
    "start": "NODE_ENV=development ng serve --host localhost --port 4200 --configuration=de | tee frontend-dev.log",
    "start:de": "ng serve --configuration=de",
    "start:en": "ng serve --configuration=en",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "nodemon ./backend/server.js",
    "build:prod": "ng build --configuration production",
    "serve:prod": "node server.static.mjs",
    "serve:static": "node server.static.mjs",
    "serve:ssr:reference": "node dist/personal-website/server/server.mjs",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "serve:ssr:personal-website": "node server.static.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/platform-server": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "@angular/ssr": "^21.2.8",
    "@primeng/themes": "^21.0.3",
    "compression": "^1.7.4",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "memory-cache": "^0.2.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/localize": "^21.2.9",
    "@capsizecss/unpack": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~4.3.0",
    "@types/memory-cache": "^0.2.5",
    "@types/node": "^16.11.7",
    "browser-sync": "^3.0.0",
    "fontaine": "^0.7.0",
    "husky": "^9.1.7",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "^5.4.2"
  },
  "overrides": {
    "ajv": "^8.17.2",
    "es-define-property": "npm:@socketregistry/es-define-property@^1",
    "function-bind": "npm:@socketregistry/function-bind@^1",
    "gopd": "npm:@socketregistry/gopd@^1",
    "has-symbols": "npm:@socketregistry/has-symbols@^1",
    "has-tostringtag": "npm:@socketregistry/has-tostringtag@^1",
    "hasown": "npm:@socketregistry/hasown@^1",
    "is-interactive": "npm:@socketregistry/is-interactive@^1",
    "is-regex": "npm:@socketregistry/is-regex@^1",
    "is-unicode-supported": "npm:@socketregistry/is-unicode-supported@^1",
    "minimatch": "^10.2.1",
    "object-assign": "npm:@socketregistry/object-assign@^1",
    "safe-buffer": "npm:@socketregistry/safe-buffer@^1",
    "safe-regex-test": "npm:@socketregistry/safe-regex-test@^1",
    "safer-buffer": "npm:@socketregistry/safer-buffer@^1",
    "side-channel": "npm:@socketregistry/side-channel@^1",
    "undici": "^6.19.2"
  }
}
